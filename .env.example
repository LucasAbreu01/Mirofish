# OpenAI API
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_HEAVY=gpt-5-mini
OPENAI_MODEL_LIGHT=gpt-5-nano

# App
DEBUG=true
UPLOAD_DIR=./uploads
DATABASE_URL=sqlite+aiosqlite:///./mirofish.db

# Simulation defaults
DEFAULT_MAX_ROUNDS=10
DEFAULT_AGENT_COUNT=5
AGENT_MEMORY_LIMIT=20
MAX_DOCUMENT_CHARS=30000
